{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rudra",
  "compatibility_date": "2026-06-17",
  "observability": {
    "enabled": true
  },
  "main": "dist/server/server.js",
  "build": {
    "command": "bun run build",
    "upload": {
      "main": "dist/server/server.js"
    }
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
